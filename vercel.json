{
  "buildCommand": "bash scripts/build-www.sh",
  "outputDirectory": "www",
  "redirects": [
    { "source": "/predictions", "destination": "/accuracy.html", "permanent": true },
    { "source": "/predictions.html", "destination": "/accuracy.html", "permanent": true }
  ],
  "functions": {
    "api/predictions.js": { "maxDuration": 60 },
    "api/validate.js":    { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/predictions?resolve=true",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/predictions?news-grade=true",
      "schedule": "0 10 * * *"
    }
  ]
}
