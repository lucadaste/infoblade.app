# Supabase — copy from your Supabase project Settings > Database > Connection string
# Use the "URI" format (direct connection, port 5432)
DATABASE_URL=postgresql+asyncpg://postgres.YOURREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase API — Settings > API
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://infoblade.app,http://localhost:3000

# StockTwits — optional; leave blank to use the public unauthenticated API.
# Set this once StockTwits re-opens API key registrations to get higher rate
# limits (400 req/hr vs 200 req/hr) and access to premium endpoints.
STOCKTWITS_ACCESS_TOKEN=

# Tickers the scheduler auto-ingests every hour (comma-separated)
TRACKED_TICKERS=AAPL,TSLA,NVDA,MSFT,AMZN,GOOGL,META,AMD

# Signal thresholds — aggregate score above/below these becomes bullish/bearish
# Score ranges from -1.0 (fully bearish) to +1.0 (fully bullish)
SIGNAL_BULLISH_THRESHOLD=0.15
SIGNAL_BEARISH_THRESHOLD=-0.15

# Accuracy threshold for account whitelist (default 0.60)
WHITELIST_ACCURACY_THRESHOLD=0.60

# Minimum calls before an account is scored (default 20)
WHITELIST_MIN_CALLS=20
